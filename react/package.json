{
  "name": "zuki-react",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:app": "vite build",
    "build:lib": "vite build -c vite.lib.config.js",
    "build": "npm run build:lib && npm run build:app",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "main": "dist-lib/zuki-react.umd.js",
  "module": "dist-lib/zuki-react.es.js",
  "exports": {
    ".": {
      "import": "./dist-lib/zuki-react.es.js",
      "require": "./dist-lib/zuki-react.umd.js"
    },
    "./style.css": "./dist-lib/zuki-react.css"
  },
  "files": [
    "dist-lib"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}